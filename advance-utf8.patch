+     * Validate advance adjustment lines and enrich with advance_transaction_id.
+     *
+     * @param  array<int, array{fund_id: int, amount: float}>  $lines
+     * @return array<int, array{fund_id: int, amount: float, advance_transaction_id: int}>
+     */
+    private function resolveAdvanceAdjustments(array $lines): array
+    {
+        $resolved = [];
+
+        foreach ($lines as $line) {
+            $fundId = (int) ($line['fund_id'] ?? 0);
+            $amount = round((float) ($line['amount'] ?? 0), 3);
+
+            if ($amount <= 0 || $fundId <= 0) {
+                continue;
+            }
+
+            $fund = PurchaseFund::query()
+                ->where('id', $fundId)
+                ->where('status', 'completed')
+                ->whereNotNull('transaction_id')
+                ->first();
+
+            if (! $fund) {
+                throw new \DomainException("Advance fund #{$fundId} not found or not yet released.");
+            }
+
+            $advanceTxn = Transaction::query()->find($fund->transaction_id);
+
+            if (! $advanceTxn) {
+                throw new \DomainException("Advance transaction for fund #{$fundId} not found.");
+            }
+
+            $remaining = $advanceTxn->remainingAdvance();
+
+            if ($amount > round($remaining, 3)) {
+                throw new \DomainException(sprintf(
+                    'Adjustment amount %s for fund #%d exceeds remaining advance of %s.',
+                    number_format($amount, 2),
+                    $fundId,
+                    number_format($remaining, 2)
+                ));
+            }
+
+            $resolved[] = [
+                'fund_id'                => $fundId,
+                'amount'                 => $amount,
+                'advance_transaction_id' => (int) $fund->transaction_id,
+            ];
+        }
+
+        return $resolved;
+    }
+
+    private function resolveAdvanceAccountId(): int
+    {
+        $account = Account::query()
+            ->whereRaw('LOWER(name) = ?', ['advance'])
+            ->value('id');
+
+        if (! $account) {
+            throw new \DomainException(
+                'Advance account not found. Please create a ledger account named "Advance" in the chart of accounts.'
+            );
+        }
+
+        return (int) $account;
+    }
