Table users {
  id bigint [pk]
  name string
  phone string
  country_code string
  phone_without_cc string
  country_name_short string
  email string
  password string
  email_verified_at timestamp
  image_id int [ref:>files.id]
  updated_at timestamp
  created_at timestamp
}

Table roles { //done
id bigint [pk]
name string //admin,newuser,client etc
updated_at timestamp
created_at timestamp
}

Table panels { //done
id bigint [pk]
name string //admin,client
updated_at timestamp
created_at timestamp
}

Table users_panels_pivot { //done
id bigint [pk]
user_id bigint [ref: >users.id]
panel_id bigint [ref:> panels.id]
updated_at timestamp
created_at timestamp
}

Table user_role_pivot { //spite default
id bigint [pk]
user_id bigint [ref: > users.id]
role_id bigint [ref: > roles.id]
updated_at timestamp
created_at timestamp
}

Table files { //done
id integer [pk]
user_id bigint [ref: >users.id]
name text
caption text
type string //image/video/zip/audio/others
extension string
updated_at timestamp
created_at timestamp
}

Table file_items { //done
id integer [pk]
file_id bigint [ref: >files.id]
type string//original/thumbnail/featured/small
size string
path text
updated_at timestamp
created_at timestamp
}

// projects module
Table projects {
  id integer [pk]
  image bigint [ref: >files.id]
  name string
  code string [unique]
  project_type string //enum=type
  status string //enum=status
  location text
  start_date date
  end_date date
  budget decimal(10,2)
  description text
  documents json
  updated_at timestamp
  created_at timestamp
  deleted_at timestamp
}

Table project_plannings {
  id bigint [pk, increment]
  project_id bigint [ref: > projects.id]
  name string
  start_date date [null]
  end_date date [null]
  duration_days int [null]
  notes text [null]
  documents json [ref: >files.id]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
}

Table tasks {
  id bigint [pk, increment]
  project_id bigint [ref: > projects.id]
  name string
  start_date date [null]
  end_date date [null]
  duration_days int [null]
  status string //enum
  documents json [ref: >files.id]
  notes text [null]
  created_at timestamp
  updated_at timestamp
}

Table project_estimates {
  id bigint [pk, increment]

  project_id bigint
  title string
  description text [null]

  status string [note: 'draft | approved | revised | cancelled | pending', default: 'draft'] //status value from enum files

  total_material_cost decimal(15,2) [default: 0]
  total_labor_cost decimal(15,2) [default: 0]
  total_equipment_cost decimal(15,2) [default: 0]
  total_transport_cost decimal(15,2) [default: 0]
  total_subcontract_cost decimal(15,2) [default: 0]
  total_overhead_cost decimal(15,2) [default: 0]
  grand_total decimal(15,2) [default: 0]
  created_by bigint [ref:>users.id]
  created_by_name string
  documents json [ref: >files.id]
  authority_approved_at timestamp
  gm_approved_at timestamp
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
}

Table project_estimate_sections {
  id bigint [pk, increment]

  project_estimate_id bigint
  project_id bigint

  name string [note: 'Materials, Labor / Workers, Equipment, Transportation, Subcontract / Services, Overhead / Misc']
  type string [note: 'material | labor | equipment | transport | subcontract | overhead']
  sort_order int [default: 0]

  notes text [null]

  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
}

Table project_estimate_items {
  id bigint [pk, increment]

  project_estimate_id bigint
  project_estimate_section_id bigint
  project_id bigint

  type string [note: 'material | labor | equipment | transport | subcontract | overhead']
  name string

  meterial_id bigint [null, note: 'nullable, only for material if linked with products']

  quantity decimal(15,2) [default: 0]
  unit string [null]
  rate decimal(15,2) [default: 0]
  total_cost decimal(15,2) [default: 0]

  remarks text [null]
  sort_order int [default: 0]

  created_at timestamp
  updated_at timestamp
  deleted_at timestamp [null]
}


Table properties {
  id integer [pk]
  project_id bigint [ref: > projects.id]
  updated_at timestamp
  created_at timestamp
}

//materials
Table product_categories {
  id integer [pk]
  name string
  slug string [unique]
  image_id bigint [ref: > files.id, null]
  description text
  parent_id bigint [ref: > product_categories.id, null]
  created_at timestamp
  updated_at timestamp
}

Table product_brands {
  id integer [pk]
  name string
  slug string [unique]
  image string [null]
  description text
  created_at timestamp
  updated_at timestamp
}

Table products {
  id integer [pk]
  name string
  category_id bigint [ref: > product_categories.id]
  brand_id bigint [ref: > product_brands.id]
  description text
  unit string
  created_at timestamp
  updated_at timestamp
}
Table product_units{
  id integer [pk]
  name string
  slug string [unique]
  created_at timestamp
  updated_at timestamp
}

Table stores {
  id bigint [pk, increment]
  name varchar //store name= Bashundhara office store  etc
  code varchar [unique] // unique code for store
  type varchar // type from enum office or project
  project_id bigint [null]
  address string [null]
  description text [null]
  status boolean [default: true] //active/inactive
  created_at timestamp
  updated_at timestamp
}

Table stocks {
 id bigint [pk, increment]
 supplier_id bigint [null]
 supplier_voucer string
 store_register_number string [unique,null]
 store_id bigint [ref:>stores.id]
 product_id bigint [ref:>products.id]
 quantity decimal(10,3)
 type string //value from file enum = purchased,received,send,adjustment,consumption
 stock_type string //value from file enum = in/out
  created_at timestamp
  updated_at timestamp
}

Table transfer_transaction{
  id bigint [pk, increment]
  sender_store_id bigint [ref:>stores.id]
  receiver_store_id bigint [ref:>stores.id]
  is_requested boolean
  store_man_approved_at timestamp
  user_id bigint [ref:users.id]
  created_at timestamp
  updated_at timestamp
}

Table transfer_items{
  id bigint [pk, increment]
  transfer_transaction_id bigint [ref:>transfer_transaction.id]
  product_id bigint [ref:>products.id]
  quantity decimal(10,3)
  checked_by_sender boolean
  checked_by_reciever boolean
  created_at timestamp
  updated_at timestamp
}

Table suppliers {
  id bigint [pk, increment]
  name varchar(150)
}

//For accounts Module
// =========================
// ACCOUNTS / COA
// =========================
Table accounts {
  id bigint [pk, increment]
  parent_id bigint [ref: > accounts.id, null]
  code varchar(50) [null]
  name varchar(150)
  type varchar(30) // asset, liability, income, expense, equity
  is_active boolean [default: true]
  created_at timestamp
  updated_at timestamp
}


// =========================
// ACCOUNTING TRANSACTION HEADER
// =========================
Table transactions {
  id bigint [pk, increment]
  date date
  type varchar(50) // payment, collection, expense, journal
  reference_type varchar(100) [null] // purchase_order, expense, payment, collection, payable, project, supplier etc
  reference_id bigint [null]
  notes text [null]
  created_by bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}


// =========================
// ACCOUNTING TRANSACTION LINES
// =========================
Table transaction_lines {
  id bigint [pk, increment]
  transaction_id bigint [ref: > transactions.id]
  account_id bigint [ref: > accounts.id]
  debit decimal(15,3) [default: 0]
  credit decimal(15,3) [default: 0]
  description varchar(255) [null]
  created_at timestamp
  updated_at timestamp
}


// =========================
// PAYMENTS
// =========================
Table payments {
  id bigint [pk, increment]
  transaction_id bigint [ref: > transactions.id]
  payment_no varchar(50) [null]
  date date
  method varchar(30) // cash, bank, cheque, mobile_banking
  payment_account_id bigint [ref: > accounts.id] // cash/bank account
  purpose_account_id bigint [ref: > accounts.id, null] // debit side account for double-entry
  amount decimal(14,2)
  payee_name varchar(150) [null]
  reference_type varchar(100) [null]
  reference_id bigint [null]

  notes text [null]
  created_by bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}


// =========================
// COLLECTIONS / RECEIPTS
// =========================
Table collections {
  id bigint [pk, increment]
  transaction_id bigint [ref: > transactions.id]

  collection_no varchar(50) [null]
  date date
  method varchar(30) // cash, bank, cheque, mobile_banking

  collection_account_id bigint [ref: > accounts.id] // cash/bank account
  target_account_id bigint [ref: > accounts.id, null] // credit side account for double-entry
  amount decimal(14,2)

  payer_name varchar(150) [null]
  collection_type varchar(50) // property_sale, rent, other

  reference_type varchar(100) [null]
  reference_id bigint [null]

  notes text [null]
  created_by bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}


// =========================
// EXPENSES
// =========================
Table expenses {
  id bigint [pk, increment]
  transaction_id bigint [ref: > transactions.id]

  expense_no varchar(50) [null]
  date date
  title varchar(150)

  reference_type varchar(100) [null]
  reference_id bigint [null]

  expense_account_id bigint [ref: > accounts.id]
  payment_account_id bigint [ref: > accounts.id] // cash/bank account

  amount decimal(14,2)
  notes text [null]

  created_by bigint [ref: > users.id]
  created_at timestamp
  updated_at timestamp
}


// =========================
// PURCHASE PAYABLES
// =========================
Table purchase_payables {
  id bigint [pk, increment]

  purchase_order_id bigint [ref: > purchase_orders.id]
  supplier_id bigint [ref: > suppliers.id, null] // keep for double check

  transaction_id bigint [ref: > transactions.id, null]

  payable_amount decimal(14,2)
  paid_amount decimal(14,2) [default: 0]
  due_amount decimal(14,2)

  status varchar(30) // unpaid, partial, paid

  created_at timestamp
  updated_at timestamp
}


// =========================
// HRM + Payroll + Advance
// =========================

Table departments {
  id bigint [pk, increment]
  name varchar(150)
  code varchar(50) [null]
  status boolean [default: true]
  created_at timestamp
  updated_at timestamp
}

Table designations {
  id bigint [pk, increment]
  department_id bigint [null, ref: > departments.id]
  name varchar(150)
  code varchar(50) [null]
  status boolean [default: true]
  created_at timestamp
  updated_at timestamp
}

Table employees {
  id bigint [pk, increment]
  department_id bigint [null, ref: > departments.id]
  designation_id bigint [null, ref: > designations.id]
  user_id bigint [null, unique, ref: > users.id]

  employee_id varchar(50) [unique]
  name varchar(150)
  phone varchar(30) [null]
  email varchar(150) [null]
  gender varchar(20) [null]
  date_of_birth date [null]

  joining_date date
  confirmation_date date [null]
  exit_date date [null]

  employment_type varchar(50) [null] // permanent, contractual, intern, daily
  basic_salary decimal(14,2) [default: 0]

  status varchar(30) [default: 'active'] // active, inactive, resigned, terminated
  has_login boolean [default: false]

  photo_file_id bigint [null, ref: > files.id]
  address text [null]
  notes text [null]

  created_at timestamp
  updated_at timestamp
}

Table salary_structures {
  id bigint [pk, increment]
  employee_id bigint [ref: > employees.id]

  effective_from date

  basic_salary decimal(14,2) [default: 0]
  house_rent decimal(14,2) [default: 0]
  medical_allowance decimal(14,2) [default: 0]
  transport_allowance decimal(14,2) [default: 0]
  food_allowance decimal(14,2) [default: 0]
  other_allowance decimal(14,2) [default: 0]

  gross_salary decimal(14,2) [default: 0]

  status boolean [default: true]
  notes text [null]

  created_at timestamp
  updated_at timestamp
}

Table payrolls {
  id bigint [pk, increment]
  employee_id bigint [ref: > employees.id]
  salary_structure_id bigint [null, ref: > salary_structures.id]
  transaction_id bigint [null] // accounts transaction for payroll generation

  month tinyint
  year smallint
  payroll_date date [null]

  basic_salary decimal(14,2) [default: 0]
  allowance_total decimal(14,2) [default: 0]
  bonus_total decimal(14,2) [default: 0]
  deduction_total decimal(14,2) [default: 0]
  gross_salary decimal(14,2) [default: 0]
  net_salary decimal(14,2) [default: 0]

  payment_status varchar(30) [default: 'pending'] // pending, partial, paid, cancelled
  payment_date date [null] // optional summary field

  notes text [null]
  generated_by bigint [null, ref: > users.id]
  approved_by bigint [null, ref: > users.id]
  created_at timestamp
  updated_at timestamp

  indexes {
    (employee_id, month, year) [unique]
  }
}

Table payroll_items {
  id bigint [pk, increment]
  payroll_id bigint [ref: > payrolls.id]

  type varchar(30) // earning, bonus, deduction
  label varchar(100)
  amount decimal(14,2) [default: 0]
  sort_order int [default: 0]

  created_at timestamp
  updated_at timestamp
}

Table employee_advances {
  id bigint [pk, increment]
  employee_id bigint [ref: > employees.id]
  transaction_id bigint [null] // accounts transaction for advance payment

  advance_date date
  amount decimal(14,2) [default: 0]

  adjusted_amount decimal(14,2) [default: 0]
  remaining_amount decimal(14,2) [default: 0]

  status varchar(30) [default: 'pending'] // pending, partial, cleared, cancelled
  notes text [null]

  created_by bigint [null, ref: > users.id]
  approved_by bigint [null, ref: > users.id]

  created_at timestamp
  updated_at timestamp
}

Table employee_advance_adjustments {
  id bigint [pk, increment]
  employee_advance_id bigint [ref: > employee_advances.id]
  payroll_id bigint [ref: > payrolls.id]

  amount decimal(14,2) [default: 0]
  adjustment_date date
  notes text [null]

  created_at timestamp
  updated_at timestamp
}

Table payroll_payments {
  id bigint [pk, increment]
  payroll_id bigint [ref: > payrolls.id]
  transaction_id bigint [null] // accounts transaction for actual salary payment

  payment_date date
  amount decimal(14,2) [default: 0]
  payment_method varchar(50) [null] // cash, bank, mobile_banking
  reference_no varchar(100) [null]
  notes text [null]

  received_by bigint [null, ref: > users.id]
  created_at timestamp
  updated_at timestamp
}
